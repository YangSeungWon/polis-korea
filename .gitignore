.env
.env.*
*.log
.DS_Store
__pycache__/
*.pyc
.venv/
node_modules/
.claude/

# raw 데이터 (가공 결과는 커밋)
# 디렉터리 자체가 아닌 "내용물"을 무시해야 아래 예외(!) 재포함이 동작함.
data/raw/*
data/*.csv
data/*.xlsx
data/*.xls

# 예외: 무투표 당선구 캐시 (공개 선거데이터·소량 — 커밋해 키 없이 재현 가능)
!data/raw/nec_uncontested/
# 예외: 후보 정당·직위 캐시 (NEC 후보자검색 결과·공개데이터 — 커밋해 키 없이 재현)
!data/raw/nec_candidate_party.json
!data/raw/nec_candidate_office.json
# 예외: NEC 등록후보 명부 (산점도 등록/사전거론 구분용·런타임 fetch·공개데이터)
!data/raw/nec_roster_9th.json
# 예외: 22대 총선 선거구별 후보 명부 (NEC 개표결과 xlsx 추출·공개데이터)
!data/raw/nec_roster_22gen.json
# 예외: raw 카탈로그 — 다른 머신·새 clone에서 재현 가능하도록 manifest 추적
!data/raw/MANIFEST.json
# 예외: VT012 정기조사 목록 — CI cold run이 scrape를 증분으로 시작하게(0부터 재스크랩 방지). tracker 소스 list.
!data/raw/nesdc_etc_polls.csv
*.manual.bak
!data/raw/nec_roster_21gen.json
!data/raw/nec_roster_20gen.json
!data/raw/nec_roster_7th.json
